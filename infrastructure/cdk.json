{
  "app": "npx ts-node --prefer-ts-exts bin/duseum.ts",
  "toolkitStackName": "duseum-cdk-toolkit",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      ".git",
      "cdk.out",
      "dist"
    ]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/aws-cognito:advancedSecurityModeIsNotStringType": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "certArn.dev":  "arn:aws:acm:us-east-1:408141212087:certificate/PLACEHOLDER-DEV-CERT",
    "certArn.prod": "arn:aws:acm:us-east-1:408141212087:certificate/PLACEHOLDER-PROD-CERT",
    "cloudfrontKeyPairId.dev":  "PLACEHOLDER-DEV-KEYPAIR-ID",
    "cloudfrontKeyPairId.prod": "PLACEHOLDER-PROD-KEYPAIR-ID"
  }
}
