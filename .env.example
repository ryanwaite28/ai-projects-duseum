# =============================================================================
# .env.example — Duseum local development environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values for local dev.
# Lambda functions running against MiniStack use these directly via tsx.
# In deployed environments (dev/prod), CDK injects all values from SSM and
# Secrets Manager — these env vars are never committed or hardcoded.
#
# Usage:
#   cp .env.example .env.local
#   # Edit .env.local with your local Stripe test keys
#   docker-compose up -d
#   npm run dev:lambdas
# =============================================================================

# Runtime environment (local | dev | prod)
ENVIRONMENT=local

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=duseum-local
IDEMPOTENCY_TABLE_NAME=duseum-local-idempotency
CONFIG_TABLE_NAME=duseum-local-config

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_MEDIA_BUCKET=duseum-local-media

# ── CloudFront ────────────────────────────────────────────────────────────────
CLOUDFRONT_MEDIA_DOMAIN=localhost:4566
CLOUDFRONT_KEY_PAIR_ID=REPLACE_ME

# ── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=REPLACE_ME
COGNITO_CLIENT_ID=REPLACE_ME

# ── AWS local endpoint (MiniStack) ────────────────────────────────────────────
# Set this to point all AWS SDK calls at MiniStack instead of real AWS
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── SQS queue URLs (MiniStack local) ──────────────────────────────────────────
STRIPE_WEBHOOK_QUEUE_URL=http://localhost:4566/000000000000/duseum-local-stripe-webhooks
NOTIFICATIONS_QUEUE_URL=http://localhost:4566/000000000000/duseum-local-notifications

# ── EventBridge rule names (maintenance-lambda only) ─────────────────────────
DAILY_FEATURE_RULE_NAME=duseum-local-daily-featured-author
WEEKLY_ROTATION_RULE_NAME=duseum-local-weekly-feature-rotation

# ── Stripe (local test keys — never use live keys here) ───────────────────────
# Secrets are read from Secrets Manager (MiniStack) at Lambda cold start,
# NOT from env vars in deployed environments. These are local dev convenience
# values only — real secrets stored at duseum/local/stripe/* in MiniStack.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_CONNECT_CLIENT_ID=ca_REPLACE_ME

# ── Frontend (Vite exposes VITE_* vars to the browser bundle) ─────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_COGNITO_USER_POOL_ID=REPLACE_ME
VITE_COGNITO_CLIENT_ID=REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
