# =============================================================================
# scripts/.secrets.env.example
# =============================================================================
# Copy this file to scripts/.secrets.env and fill in the real values.
#
# ⚠ NEVER commit .secrets.env to git — it is gitignored.
# ⚠ NEVER share this file.
#
# Usage:
#   cp scripts/.secrets.env.example scripts/.secrets.env
#   # edit scripts/.secrets.env with real values
#   aws sso login --profile rmw-llc
#   bash scripts/bootstrap.sh
# =============================================================================

# ── DEV (Sandbox) Stripe secrets ──────────────────────────────────────────────
DEV_STRIPE_SK=sk_test_REPLACE_WITH_DEV_SECRET_KEY
DEV_STRIPE_WHSEC=whsec_REPLACE_WITH_DEV_CONNECT_WEBHOOK_SECRET
DEV_STRIPE_WHSEC_ACCOUNT=whsec_REPLACE_WITH_DEV_ACCOUNT_WEBHOOK_SECRET

# ── PROD (Live) Stripe secrets ────────────────────────────────────────────────
PROD_STRIPE_SK=sk_live_REPLACE_WITH_PROD_SECRET_KEY
PROD_STRIPE_WHSEC=whsec_REPLACE_WITH_PROD_CONNECT_WEBHOOK_SECRET
PROD_STRIPE_WHSEC_ACCOUNT=whsec_REPLACE_WITH_PROD_ACCOUNT_WEBHOOK_SECRET
