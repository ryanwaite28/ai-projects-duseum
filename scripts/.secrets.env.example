# =============================================================================
# scripts/.secrets.env.example — Bootstrap secret inputs
# =============================================================================
# Copy this file to scripts/.secrets.env and fill in the real values.
#
# ⚠ NEVER commit .secrets.env to git — it is gitignored.
# ⚠ NEVER share this file.
#
# WHAT bootstrap.sh CREATES FOR YOU (you do not need to do these manually):
#   Section 1–2:  Stripe keys + webhook secrets stored in Secrets Manager
#   Section 3:    Stripe publishable keys stored in SSM Parameter Store
#   Section 3.5:  CI/CD S3 artifact bucket (duseum-cicd-artifacts)
#   Section 3.6:  DynamoDB config table rows (static keys: cut%, limits, slots)
#   Section 3.7:  Stripe platform subscription product + price ($10/month),
#                 then seeds PLATFORM_SUB_PRICE_ID into the config table
#   Section 4:    CloudFront RSA key pairs + key groups (for signed URLs)
#   Section 5:    GitHub Actions OIDC provider
#   Section 6:    GitHub Actions IAM deploy roles (dev + prod + build)
#
# USAGE:
#   cp scripts/.secrets.env.example scripts/.secrets.env
#   # fill in the values below
#   aws sso login --profile rmw-llc
#   bash scripts/bootstrap.sh
# =============================================================================

# ── DEV (Sandbox) Stripe secrets ──────────────────────────────────────────────
# Required: Stripe test-mode secret key (sk_test_...)
DEV_STRIPE_SK=sk_test_REPLACE_WITH_DEV_SECRET_KEY

# Required: Stripe Connect webhook signing secret for dev
# (whsec_... from Stripe Dashboard → Webhooks → Connect webhook endpoint)
DEV_STRIPE_WHSEC=whsec_REPLACE_WITH_DEV_CONNECT_WEBHOOK_SECRET

# Required: Stripe account webhook signing secret for dev
# (whsec_... from Stripe Dashboard → Webhooks → Account webhook endpoint)
DEV_STRIPE_WHSEC_ACCOUNT=whsec_REPLACE_WITH_DEV_ACCOUNT_WEBHOOK_SECRET

# Optional: existing Stripe Price ID for the dev platform subscription.
# Leave blank on FIRST RUN — bootstrap.sh creates the product + price for you
# and stores the price ID in SSM (/duseum/dev/stripe/platform_price_id).
# Set this on RE-RUNS only if you want to force a specific existing price:
#   DEV_STRIPE_PRICE_ID=price_xxxx
DEV_STRIPE_PRICE_ID=

# ── PROD (Live) Stripe secrets ────────────────────────────────────────────────
# Required: Stripe live-mode secret key (sk_live_...)
PROD_STRIPE_SK=sk_live_REPLACE_WITH_PROD_SECRET_KEY

# Required: Stripe Connect webhook signing secret for prod
PROD_STRIPE_WHSEC=whsec_REPLACE_WITH_PROD_CONNECT_WEBHOOK_SECRET

# Required: Stripe account webhook signing secret for prod
PROD_STRIPE_WHSEC_ACCOUNT=whsec_REPLACE_WITH_PROD_ACCOUNT_WEBHOOK_SECRET

# Optional: existing Stripe Price ID for the prod platform subscription.
# Leave blank on FIRST RUN — bootstrap.sh creates the product + price for you.
# Set this on RE-RUNS only if you want to force a specific existing price:
#   PROD_STRIPE_PRICE_ID=price_xxxx
PROD_STRIPE_PRICE_ID=
